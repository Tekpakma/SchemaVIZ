openapi: 3.0.3
info:
  title: Drawing API
  version: 1.0.0
  description: API to manage drawings and their elements
paths:
  /schema-viz/apps/:
    get:
      operationId: schemaVizAppsRetrieve
      description: Get all apps that have at least one accessible model
      summary: List Apps
      tags:
      - Schema Introspection
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/AppsListResponse'
          description: ''
        '500':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/AppsErrorResponse'
          description: ''
  /schema-viz/drawings/:
    get:
      operationId: schemaVizDrawingsList
      description: Returns all drawings owned by the authenticated user.
      summary: List Drawings
      tags:
      - Drawings
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: '#/components/schemas/Drawing'
          description: ''
    post:
      operationId: schemaVizDrawingsCreate
      description: Creates a new drawing for the authenticated user.
      summary: Create Drawing
      tags:
      - Drawings
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/DrawingRequest'
        required: true
      security:
      - cookieAuth: []
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Drawing'
          description: ''
  /schema-viz/drawings/{id}/:
    get:
      operationId: schemaVizDrawingsRetrieve
      description: Returns a single drawing by ID. Must be owned by the authenticated
        user.
      summary: Get Drawing
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        description: A UUID string identifying this drawing.
        required: true
      tags:
      - Drawings
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Drawing'
          description: ''
    put:
      operationId: schemaVizDrawingsUpdate
      description: Fully replaces a drawing's data.
      summary: Update Drawing
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        description: A UUID string identifying this drawing.
        required: true
      tags:
      - Drawings
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/DrawingRequest'
        required: true
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Drawing'
          description: ''
    patch:
      operationId: schemaVizDrawingsPartialUpdate
      description: Partially updates a drawing.
      summary: Patch Drawing
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        description: A UUID string identifying this drawing.
        required: true
      tags:
      - Drawings
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PatchedDrawingRequest'
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Drawing'
          description: ''
    delete:
      operationId: schemaVizDrawingsDestroy
      description: Deletes a drawing permanently.
      summary: Delete Drawing
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        description: A UUID string identifying this drawing.
        required: true
      tags:
      - Drawings
      security:
      - cookieAuth: []
      responses:
        '204':
          description: No response body
  /schema-viz/drawings/{id}/export/:
    get:
      operationId: schemaVizDrawingsExportRetrieve
      description: Export a drawing as draw.io XML or rendered SVG. Use `exportFormat=drawio`
        for diagrams.net XML, or `exportFormat=svg` for deterministic image rendering
        from stored graph data.
      summary: Export Drawing
      parameters:
      - in: query
        name: background
        schema:
          type: string
          default: '#ffffff'
        description: 'Export background: hex color (#rrggbb) or ''transparent''. Defaults
          to #ffffff.'
      - in: query
        name: exportFormat
        schema:
          type: string
          enum:
          - drawio
          - svg
          default: drawio
        description: Export format.
      - in: query
        name: height
        schema:
          type: integer
        description: 'SVG canvas height in pixels. Defaults to 1080. Allowed range:
          256..8000.'
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        required: true
      - in: query
        name: mode
        schema:
          type: string
          enum:
          - current
          - fit
          default: fit
        description: SVG render mode. 'fit' fits and centers all nodes. 'current'
          uses saved viewport.
      - in: query
        name: width
        schema:
          type: integer
        description: 'SVG canvas width in pixels. Defaults to 1920. Allowed range:
          256..8000.'
      tags:
      - Drawings
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/xml:
              schema:
                type: string
            image/svg+xml:
              schema:
                type: string
          description: ''
        '404':
          content:
            application/json:
              schema:
                description: Drawing not found
          description: ''
  /schema-viz/drawings/import/:
    post:
      operationId: schemaVizDrawingsImportCreate
      description: Uploads a `.schemeviz` drawing file, validates it on the server,
        and creates a saved drawing for the authenticated user.
      summary: Import SchemeViz Drawing File
      tags:
      - Drawings
      requestBody:
        content:
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/DrawingImportRequest'
        required: true
      security:
      - cookieAuth: []
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Drawing'
          description: ''
        '400':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
          description: ''
  /schema-viz/export/:
    post:
      operationId: schemaVizExportCreate
      description: Export a canvas snapshot as SVG or Draw.io XML. The caller sends
        the full React Flow state in the request body — no saved Drawing is required.
      summary: Stateless Canvas Export
      tags:
      - Export
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/StatelessExportRequest'
        required: true
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/xml:
              schema:
                type: string
            image/svg+xml:
              schema:
                type: string
          description: ''
        '400':
          content:
            application/json:
              schema:
                description: Validation error
          description: ''
  /schema-viz/generate/{shareSlug}/:
    get:
      operationId: schemaVizGenerateTemplateRetrieve
      description: Resolves the published template metadata for a share slug.
      summary: Get Shared Generation Template
      parameters:
      - in: path
        name: shareSlug
        schema:
          type: string
        required: true
      tags:
      - Generation Templates
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/GenerationTemplateRead'
          description: ''
        '404':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
          description: ''
  /schema-viz/generate/{shareSlug}/{recordId}/:
    get:
      operationId: schemaVizGenerateRunRetrieve
      description: Runs the published template resolved by share slug and record id.
      summary: Run Shared Generation
      parameters:
      - in: path
        name: recordId
        schema:
          type: string
        required: true
      - in: path
        name: shareSlug
        schema:
          type: string
        required: true
      tags:
      - Generation Templates
      security:
      - cookieAuth: []
      responses:
        '200':
          description: No response body
        '404':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
          description: ''
  /schema-viz/generation-runs/:
    post:
      operationId: schemaVizGenerationRunsCreate
      description: Resolves a draft, published, or inline generation definition and
        returns either a structure preview or live/share generation result.
      summary: Run Generation
      tags:
      - Generation Templates
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/GenerationRunRequestRequest'
        required: true
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/GenerationRunResponse'
          description: ''
        '400':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
          description: ''
        '404':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
          description: ''
  /schema-viz/generation-template-quick-access/:
    get:
      operationId: schemaVizGenerationTemplateQuickAccessRetrieve
      description: Returns the current user's templates ordered by most recent update
        for quick access.
      summary: Get Own Recent Generation Template Quick Access
      tags:
      - Generation Templates
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/GenerationTemplateOwnRecentQuickAccess'
          description: ''
  /schema-viz/generation-template-quick-access/featured/:
    get:
      operationId: schemaVizGenerationTemplateQuickAccessFeaturedList
      description: Returns featured published templates with preview payloads and
        limit-offset pagination.
      summary: Get Featured Generation Template Quick Access
      parameters:
      - name: limit
        required: false
        in: query
        description: Number of results to return per page.
        schema:
          type: integer
      - name: offset
        required: false
        in: query
        description: The initial index from which to return the results.
        schema:
          type: integer
      tags:
      - Generation Templates
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedGenerationTemplateQuickAccessEntryList'
          description: ''
  /schema-viz/generation-templates/:
    get:
      operationId: schemaVizGenerationTemplatesList
      description: Returns accessible generation templates with draft/published version
        summaries. Supports filtering by scope, published state, featured state, owner,
        and optional sample runs for home/library surfaces.
      summary: List Generation Templates
      tags:
      - Generation Templates
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: '#/components/schemas/GenerationTemplateList'
          description: ''
    post:
      operationId: schemaVizGenerationTemplatesCreate
      description: Creates a new draft generation template.
      summary: Create Generation Template
      tags:
      - Generation Templates
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/GenerationTemplateWriteRequest'
        required: true
      security:
      - cookieAuth: []
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/GenerationTemplateWrite'
          description: ''
  /schema-viz/generation-templates/{id}/:
    get:
      operationId: schemaVizGenerationTemplatesRetrieve
      description: Returns a single generation template with full draft and published
        versions.
      summary: Get Generation Template
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        description: A UUID string identifying this generation template.
        required: true
      tags:
      - Generation Templates
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/GenerationTemplateRead'
          description: ''
    put:
      operationId: schemaVizGenerationTemplatesUpdate
      description: Fully replaces the current draft definition and metadata.
      summary: Update Generation Template
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        description: A UUID string identifying this generation template.
        required: true
      tags:
      - Generation Templates
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/GenerationTemplateWriteRequest'
        required: true
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/GenerationTemplateWrite'
          description: ''
    patch:
      operationId: schemaVizGenerationTemplatesPartialUpdate
      description: Alias for full draft replacement.
      summary: Patch Generation Template
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        description: A UUID string identifying this generation template.
        required: true
      tags:
      - Generation Templates
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PatchedGenerationTemplateWriteRequest'
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/GenerationTemplateWrite'
          description: ''
    delete:
      operationId: schemaVizGenerationTemplatesDestroy
      description: Deletes the template container and all stored versions.
      summary: Delete Generation Template
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        description: A UUID string identifying this generation template.
        required: true
      tags:
      - Generation Templates
      security:
      - cookieAuth: []
      responses:
        '204':
          description: No response body
  /schema-viz/generation-templates/{id}/publish/:
    post:
      operationId: schemaVizGenerationTemplatesPublishCreate
      description: Snapshots the current draft as a new published version.
      summary: Publish Generation Template
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        description: A UUID string identifying this generation template.
        required: true
      tags:
      - Generation Templates
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/GenerationTemplateRead'
          description: ''
  /schema-viz/generation-templates/{id}/unpublish/:
    post:
      operationId: schemaVizGenerationTemplatesUnpublishCreate
      description: Clears the published version while keeping the current draft intact.
      summary: Unpublish Generation Template
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        description: A UUID string identifying this generation template.
        required: true
      tags:
      - Generation Templates
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/GenerationTemplateRead'
          description: ''
  /schema-viz/graph/:
    get:
      operationId: schemaVizGraphRetrieve
      description: Get complete schema graph with nodes, edges, and groups
      summary: Get Schema Graph
      tags:
      - Schema Introspection
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/SchemaGraph'
          description: ''
        '500':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/GraphErrorResponse'
          description: ''
  /schema-viz/group-templates/:
    get:
      operationId: schemaVizGroupTemplatesList
      description: |-
        Drop-in mixin for DRF views / viewsets.

        Subclasses set ``schema_viz_permission_category`` to one of:
          - ``"introspection"`` – public schema endpoints
          - ``"user_data"``     – authenticated read access
          - ``"owner"``         – authenticated + ownership checks
      tags:
      - schema-viz
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: '#/components/schemas/GroupTemplate'
          description: ''
    post:
      operationId: schemaVizGroupTemplatesCreate
      description: |-
        Drop-in mixin for DRF views / viewsets.

        Subclasses set ``schema_viz_permission_category`` to one of:
          - ``"introspection"`` – public schema endpoints
          - ``"user_data"``     – authenticated read access
          - ``"owner"``         – authenticated + ownership checks
      tags:
      - schema-viz
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/GroupTemplateRequest'
        required: true
      security:
      - cookieAuth: []
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/GroupTemplate'
          description: ''
  /schema-viz/group-templates/{id}/:
    get:
      operationId: schemaVizGroupTemplatesRetrieve
      description: |-
        Drop-in mixin for DRF views / viewsets.

        Subclasses set ``schema_viz_permission_category`` to one of:
          - ``"introspection"`` – public schema endpoints
          - ``"user_data"``     – authenticated read access
          - ``"owner"``         – authenticated + ownership checks
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        description: A UUID string identifying this group template.
        required: true
      tags:
      - schema-viz
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/GroupTemplate'
          description: ''
    put:
      operationId: schemaVizGroupTemplatesUpdate
      description: |-
        Drop-in mixin for DRF views / viewsets.

        Subclasses set ``schema_viz_permission_category`` to one of:
          - ``"introspection"`` – public schema endpoints
          - ``"user_data"``     – authenticated read access
          - ``"owner"``         – authenticated + ownership checks
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        description: A UUID string identifying this group template.
        required: true
      tags:
      - schema-viz
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/GroupTemplateRequest'
        required: true
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/GroupTemplate'
          description: ''
    patch:
      operationId: schemaVizGroupTemplatesPartialUpdate
      description: |-
        Drop-in mixin for DRF views / viewsets.

        Subclasses set ``schema_viz_permission_category`` to one of:
          - ``"introspection"`` – public schema endpoints
          - ``"user_data"``     – authenticated read access
          - ``"owner"``         – authenticated + ownership checks
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        description: A UUID string identifying this group template.
        required: true
      tags:
      - schema-viz
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PatchedGroupTemplateRequest'
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/GroupTemplate'
          description: ''
    delete:
      operationId: schemaVizGroupTemplatesDestroy
      description: |-
        Drop-in mixin for DRF views / viewsets.

        Subclasses set ``schema_viz_permission_category`` to one of:
          - ``"introspection"`` – public schema endpoints
          - ``"user_data"``     – authenticated read access
          - ``"owner"``         – authenticated + ownership checks
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        description: A UUID string identifying this group template.
        required: true
      tags:
      - schema-viz
      security:
      - cookieAuth: []
      responses:
        '204':
          description: No response body
  /schema-viz/model-details/:
    get:
      operationId: schemaVizModelDetailsRetrieve
      description: Get detailed information about a specific model including fields
        and relationships
      summary: Get Model Details
      parameters:
      - in: query
        name: appLabel
        schema:
          type: string
          minLength: 1
          maxLength: 100
        description: Django app label
        required: true
      - in: query
        name: modelName
        schema:
          type: string
          minLength: 1
          maxLength: 100
        description: Model name
        required: true
      tags:
      - Schema Introspection
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ModelInfo'
          description: ''
        '400':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ModelDetailBadRequest'
          description: ''
        '403':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ModelDetailForbidden'
          description: ''
        '404':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ModelDetailNotFound'
          description: ''
  /schema-viz/model-registry/:
    get:
      operationId: schemaVizModelRegistryList
      description: Returns staff-manageable QLab model registry entries for frontend
        administration.
      summary: List QLab Model Registry Entries
      tags:
      - System
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: '#/components/schemas/QLabRegistryEntry'
          description: ''
    post:
      operationId: schemaVizModelRegistryCreate
      description: Creates a QLab model registry entry for a frontend-selected Django
        model.
      summary: Create QLab Model Registry Entry
      tags:
      - System
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/QLabRegistryEntryRequest'
      security:
      - cookieAuth: []
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/QLabRegistryEntry'
          description: ''
  /schema-viz/model-registry/{id}/:
    get:
      operationId: schemaVizModelRegistryRetrieve
      description: Returns one QLab model registry entry for frontend administration.
      summary: Get QLab Model Registry Entry
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this Model Registry.
        required: true
      tags:
      - System
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/QLabRegistryEntry'
          description: ''
    put:
      operationId: schemaVizModelRegistryUpdate
      description: Replaces a QLab model registry entry.
      summary: Replace QLab Model Registry Entry
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this Model Registry.
        required: true
      tags:
      - System
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/QLabRegistryEntryRequest'
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/QLabRegistryEntry'
          description: ''
    patch:
      operationId: schemaVizModelRegistryPartialUpdate
      description: Partially updates status, restrictions, or allowed groups for a
        QLab model registry entry.
      summary: Patch QLab Model Registry Entry
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this Model Registry.
        required: true
      tags:
      - System
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PatchedQLabRegistryEntryRequest'
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/QLabRegistryEntry'
          description: ''
    delete:
      operationId: schemaVizModelRegistryDestroy
      description: Deletes a QLab model registry entry.
      summary: Delete QLab Model Registry Entry
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this Model Registry.
        required: true
      tags:
      - System
      security:
      - cookieAuth: []
      responses:
        '204':
          description: No response body
  /schema-viz/model-registry/candidates/:
    get:
      operationId: schemaVizModelRegistryCandidatesList
      description: Returns installed Django models that can be added to the QLab registry
        but do not yet have an entry.
      summary: List QLab Model Registry Candidate Models
      tags:
      - System
      security:
      - cookieAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                type: array
                items:
