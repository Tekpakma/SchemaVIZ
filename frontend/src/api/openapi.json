        schema:
          type: integer
          maximum: 20
          minimum: 1
          default: 5
      - in: query
        name: maxDepth
        schema:
          type: integer
          maximum: 50
          minimum: 1
          default: 12
      - in: query
        name: preferred
        schema:
          type: string
          minLength: 1
          default: ''
      - in: query
        name: startModel
        schema:
          type: string
          minLength: 1
        required: true
      - in: query
        name: waypoints
        schema:
          type: string
          minLength: 1
          default: ''
