          minLength: 1
          maxLength: 200
        exportName:
          type: string
          nullable: true
        templateId:
          type: string
          format: uuid
          nullable: true
        isGlobal:
          type: boolean
          default: false
      required:
      - name
      - templateKind
    TemplateUniquenessResponse:
      type: object
      properties:
        nameUnique:
          type: boolean
        nameMessage:
          type: string
          nullable: true
        exportNameUnique:
          type: boolean
          nullable: true
        exportNameMessage:
          type: string
          nullable: true
      required:
      - nameUnique
    TourProgress:
      type: object
      properties:
        id:
          type: integer
        status:
          allOf:
          - $ref: '#/components/schemas/TourProgressStatusEnum'
        currentStep:
          type: integer
        highestStep:
          type: integer
        metadata: {}
        startedAt:
          type: string
          format: date-time
          nullable: true
        completedAt:
          type: string
          format: date-time
          nullable: true
        createdAt:
          type: string
          format: date-time
        updatedAt:
          type: string
          format: date-time
      required:
      - completedAt
      - createdAt
      - currentStep
      - highestStep
      - id
      - metadata
      - startedAt
      - status
      - updatedAt
    TourProgressResource:
      type: object
      properties:
        key:
          type: string
        version:
          type: integer
        progress:
          allOf:
          - $ref: '#/components/schemas/TourProgress'
      required:
      - key
      - progress
      - version
    TourProgressStatusEnum:
      enum:
      - not_started
      - in_progress
      - completed
      type: string
      description: |-
        * `not_started` - Not Started
        * `in_progress` - In Progress
        * `completed` - Completed
    TourProgressUpsertRequest:
      type: object
      properties:
        status:
          $ref: '#/components/schemas/TourProgressStatusEnum'
        currentStep:
          type: integer
          minimum: 0
        highestStep:
          type: integer
          minimum: 0
        metadata:
          type: object
          additionalProperties: {}
    VisibilityEnum:
      enum:
      - visible
      - hidden
      type: string
      description: |-
        * `visible` - visible
        * `hidden` - hidden
  securitySchemes:
    cookieAuth:
      type: apiKey
      in: cookie
      name: sessionid
    oauth2:
      type: oauth2
      flows: {}
