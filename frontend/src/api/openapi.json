components:
  schemas:
    AppsErrorResponse:
      type: object
      properties:
        error:
          type: string
        details:
          type: string
      required:
      - details
      - error
    AppsListResponse:
      type: object
      properties:
        apps:
          type: array
          items:
            type: object
            additionalProperties: {}
      required:
      - apps
    AvailableLocalesEnum:
      enum:
      - en
      - de
      type: string
      description: |-
        * `en` - en
        * `de` - de
    BackendVersionResponse:
      type: object
      properties:
        version:
          type: string
      required:
      - version
    Drawing:
      type: object
      properties:
        id:
          type: string
          format: uuid
        title:
          type: string
          maxLength: 200
        description:
          type: string
        reactFlowState: {}
        lexicalState: {}
        createdAt:
          type: string
          format: date-time
        updatedAt:
          type: string
          format: date-time
        revision:
          type: integer
      required:
      - createdAt
      - revision
      - title
      - updatedAt
    DrawingImportRequest:
      type: object
      properties:
        file:
          type: string
          format: binary
      required:
      - file
    DrawingRequest:
      type: object
      properties:
        id:
          type: string
          format: uuid
        title:
          type: string
          minLength: 1
          maxLength: 200
        description:
          type: string
        reactFlowState: {}
        lexicalState: {}
      required:
      - title
    ErrorResponse:
      type: object
      properties:
        error:
          type: string
        details:
          type: string
      required:
      - error
    ExportFormatEnum:
      enum:
      - svg
      - drawio
      type: string
      description: |-
        * `svg` - SVG
        * `drawio` - Draw.io
    FieldInfo:
      type: object
      properties:
        name:
          type: string
        type:
          type: string
        verboseName:
          type: string
          nullable: true
        helpText:
          type: string
          nullable: true
        primaryKey:
          type: boolean
        'null':
          type: boolean
        blank:
          type: boolean
        maxLength:
          type: integer
          nullable: true
        choices:
          type: array
          items:
            type: object
            additionalProperties: {}
          nullable: true
      required:
      - name
      - type
    ForcedModelStatusEnum:
      enum:
      - unused
      - missing
      - ok
      - incompatible
      - inaccessible
      - stale
      type: string
      description: |-
        * `unused` - Unused
        * `missing` - Missing
        * `ok` - OK
        * `incompatible` - Incompatible
        * `inaccessible` - Inaccessible
        * `stale` - Stale
    GeneratedEdge:
      type: object
      properties:
        source:
          type: string
        target:
          type: string
        relationship:
          type: string
      required:
      - relationship
      - source
